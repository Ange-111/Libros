@{
    ViewData["Title"] = "Información";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold" style="color: #2c3e50;">📖 Sobre este sitio</h1>
        <div class="divider mx-auto" style="width: 80px; height: 3px; background: linear-gradient(90deg, #3498db, #2c3e50);"></div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg bg-primary text-white">
                <div class="card-body p-5 text-center">
                    <i class="bi bi-book-half" style="font-size: 3rem;"></i>
                    <p class="lead mt-3">
                        Este sitio fue creado como proyecto académico utilizando
                        la arquitectura MVC para compartir opiniones sobre libros.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body p-4">
                    <i class="bi bi-journal-bookmark-fill" style="font-size: 2.5rem; color: #3498db;"></i>
                    <h4 class="mt-3 fw-bold">📖 Lecturas</h4>
                    <p class="text-muted">Descubre libros populares y nuevas recomendaciones.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body p-4">
                    <i class="bi bi-chat-square-quote-fill" style="font-size: 2.5rem; color: #3498db;"></i>
                    <h4 class="mt-3 fw-bold">💬 Opiniones</h4>
                    <p class="text-muted">Conoce qué opinan otros lectores sobre sus libros favoritos.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-card">
                <div class="card-body p-4">
                    <i class="bi bi-people-fill" style="font-size: 2.5rem; color: #3498db;"></i>
                    <h4 class="mt-3 fw-bold">🤝 Comunidad</h4>
                    <p class="text-muted">Comparte tus recomendaciones y forma parte de la comunidad.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-5">
        <a href="/Home/Index" class="btn btn-primary btn-lg">
            ← Volver al inicio
        </a>
    </div>
</div>
