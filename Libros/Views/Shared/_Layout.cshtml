<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rincón de Libros</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Libros.styles.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&family=Dancing+Script:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top" style="background: linear-gradient(135deg, #1a252f 0%, #2c3e50 100%); box-shadow: 0 2px 20px rgba(0,0,0,0.1);">
            <div class="container">
           
                <a class="navbar-brand fw-bold" href="/Home/Index" style="font-family: 'Dancing Script', cursive; font-size: 2.2rem; font-weight: 700; letter-spacing: 1px; text-shadow: 2px 2px 4px rgba(0,0,0,0.2);">
                     Mi Librería
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" href="/Home/Index"><i class="bi bi-house"></i> Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Informacion"><i class="bi bi-info-circle"></i> Información</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Opiniones"><i class="bi bi-chat-dots"></i> Opiniones</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Home/Contacto"><i class="bi bi-envelope"></i> Contacto</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="text-center py-4 mt-5" style="background: linear-gradient(135deg, #1a252f 0%, #2c3e50 100%); color: #ecf0f1;">
        <div class="container">
            <p class="mb-0">© 2026 - Rincón de Opiniones de Libros | Un espacio para los amantes de la lectura</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
